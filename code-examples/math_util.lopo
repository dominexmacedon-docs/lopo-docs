# Define a function to calculate sales tax
define calculateTax = func(amount, taxRate) {
    define tax = amount * taxRate;
    return round(tax);
};

define price = 79.99;
define rate = 0.08; # 8% tax rate

define totalTax = calculateTax(price, rate);
define finalPrice = price + totalTax;

show("Base Price: " + toStr(price));
show("Tax Calculated: " + toStr(totalTax));
show("Total Amount Due: " + toStr(finalPrice));